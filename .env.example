# ─────────────────────────────────────────────────
# GameTracker — Environment Variables
# Copy this to .env and fill in real values
# ─────────────────────────────────────────────────

# ── General ─────────────────────────────────────
NODE_ENV=development
PORT=4000

# ── Database ────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/gametracker

# ── Redis ───────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT ─────────────────────────────────────────
JWT_SECRET=change-this-to-a-secure-random-string
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-this-to-another-secure-random-string
JWT_REFRESH_EXPIRES_IN=7d

# ── OAuth — Google ──────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# ── OAuth — Apple ───────────────────────────────
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=

# ── RAWG API ────────────────────────────────────
RAWG_API_KEY=
RAWG_BASE_URL=https://api.rawg.io/api

# ── CORS ────────────────────────────────────────
# Comma-separated origins for multiple (e.g. production + preview)
CORS_ORIGIN=http://localhost:3000

# ── Frontend API URL (set in Vercel env vars) ───
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1

# ── Rate Limiting ───────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ── Docker Production (docker-compose.prod.yml) ──
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-this-password
POSTGRES_DB=gametracker
REDIS_PASSWORD=change-this-redis-password
PUBLIC_PORT=80
