{
  "name": "gamecase",
  "version": "1.0.0",
  "private": true,
  "description": "A Goodreads-like platform for video games",
  "workspaces": [
    "packages/shared",
    "packages/backend",
    "packages/web"
  ],
  "scripts": {
    "dev:backend": "npm run dev -w packages/backend",
    "dev:web": "npm run dev -w packages/web",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:web\"",
    "build:shared": "npm run build -w packages/shared",
    "build:backend": "npm run build -w packages/backend",
    "build:web": "npm run build -w packages/web",
    "build": "npm run build:shared && concurrently \"npm run build:backend\" \"npm run build:web\"",
    "lint": "eslint packages/*/src --ext .ts,.tsx",
    "format": "prettier --write \"packages/*/src/**/*.{ts,tsx,json,css}\"",
    "format:check": "prettier --check \"packages/*/src/**/*.{ts,tsx,json,css}\"",
    "db:migrate": "npm run migrate -w packages/backend",
    "db:seed": "npm run seed -w packages/backend",
    "db:studio": "npm run studio -w packages/backend",
    "clean": "rimraf packages/*/dist packages/*/node_modules/.cache packages/web/.next"
  },
  "keywords": [
    "games",
    "tracker",
    "library"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "concurrently": "^9.2.1",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "optionalDependencies": {
    "@esbuild/win32-x64": "^0.27.3"
  }
}
